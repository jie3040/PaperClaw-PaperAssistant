{
  "models": {
    "providers": {
      "openrouter": {
        "baseUrl": "https://openrouter.ai/api/v1",
        "apiKey": "YOUR_API_KEY_HERE",
        "api": "openai-completions",
        "models": [
          {
            "id": "xiaomi/mimo-v2-pro",
            "name": "xiaomi/mimo-v2-pro",
            "reasoning": true,
            "input": [
              "text",
              "image"
            ],
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "contextWindow": 200000,
            "maxTokens": 16000
          }
        ]
      }
    }
  },
  "agents": {
    "list": [
      {
        "id": "main",
        "default": true,
        "identity": {
          "name": "Leader",
          "emoji": "👑"
        },
        "model": {
          "primary": "openrouter/xiaomi/mimo-v2-pro"
        },
        "workspace": "/home/liaowenjie/.openclaw-multi/leader/workspace"
      }
    ],
    "defaults": {
      "model": {
        "primary": "openrouter/xiaomi/mimo-v2-pro"
      },
      "workspace": "/home/liaowenjie/.openclaw-multi/leader/workspace",
      "compaction": {
        "mode": "safeguard"
      },
      "heartbeat": {
        "every": "5m"
      }
    }
  },
  "tools": {
    "profile": "full",
    "web": {
      "search": {
        "enabled": true,
        "apiKey": "YOUR_API_KEY_HERE"
      },
      "fetch": {
        "enabled": true
      }
    }
  },
  "hooks": {
    "enabled": true,
    "token": "leader-hook-2026",
    "path": "/hooks",
    "allowRequestSessionKey": true,
    "allowedSessionKeyPrefixes": [
      "hook:"
    ]
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto"
  },
  "gateway": {
    "port": 18800,
    "mode": "local",
    "bind": "loopback",
    "auth": {
      "mode": "token",
      "token": "leader-gw-2026"
    },
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    }
  },
  "skills": {
    "install": {
      "nodeManager": "npm"
    }
  },
  "channels": {
    "feishu": {
      "enabled": true,
      "appId": "YOUR_FEISHU_APP_ID",
      "appSecret": "YOUR_FEISHU_APP_SECRET",
      "domain": "feishu",
      "connectionMode": "websocket",
      "dmPolicy": "open",
      "allowFrom": [
        "*"
      ],
      "groupPolicy": "allowlist",
      "requireMention": true,
      "renderMode": "auto"
    }
  },
  "plugins": {
    "entries": {
      "feishu": {
        "enabled": true
      }
    },
    "installs": {
      "@m1heng-clawd/feishu": {
        "source": "npm"
      }
    }
  }
}