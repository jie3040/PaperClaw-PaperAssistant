{
  "models": {
    "providers": {
      "openrouter": {
        "baseUrl": "https://openrouter.ai/api/v1",
        "apiKey": "YOUR_API_KEY_HERE",
        "api": "openai-completions",
        "models": [
          {
            "id": "z-ai/glm-5-turbo",
            "name": "z-ai/glm-5-turbo",
            "reasoning": true,
            "input": [
              "text",
              "image"
            ],
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "contextWindow": 200000,
            "maxTokens": 16000
          }
        ]
      }
    }
  },
  "agents": {
    "list": [
      {
        "id": "main",
        "default": true,
        "identity": {
          "name": "Editor",
          "emoji": "📝"
        },
        "model": {
          "primary": "openrouter/z-ai/glm-5-turbo"
        },
        "workspace": "/home/liaowenjie/.openclaw-multi/editor/workspace"
      }
    ],
    "defaults": {
      "model": {
        "primary": "openrouter/z-ai/glm-5-turbo"
      },
      "workspace": "/home/liaowenjie/.openclaw-multi/editor/workspace",
      "compaction": {
        "mode": "safeguard"
      },
      "heartbeat": {
        "every": "0m"
      }
    }
  },
  "tools": {
    "profile": "full",
    "web": {
      "search": {
        "enabled": true,
        "apiKey": "YOUR_API_KEY_HERE"
      },
      "fetch": {
        "enabled": true
      }
    }
  },
  "hooks": {
    "enabled": true,
    "token": "editor-hook-2026",
    "path": "/hooks",
    "allowRequestSessionKey": true,
    "allowedSessionKeyPrefixes": [
      "hook:"
    ]
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto"
  },
  "gateway": {
    "port": 18870,
    "mode": "local",
    "bind": "loopback",
    "auth": {
      "mode": "token",
      "token": "editor-gw-2026"
    },
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    }
  },
  "skills": {
    "install": {
      "nodeManager": "npm"
    }
  },
  "plugins": {
    "entries": {},
    "installs": {}
  }
}